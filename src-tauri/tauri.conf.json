{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreeYourDisk",
  "version": "0.1.0",
  "identifier": "io.freeyourdisk",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FreeYourDisk",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      },
      {
        "label": "tray",
        "url": "index.html",
        "width": 320,
        "height": 470,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Safe disk cleanup utility",
    "longDescription": "Scan your disk and safely clean temporary files, large files, stale git worktrees and developer caches, with a modern visual dashboard.",
    "linux": {
      "deb": {
        "depends": [
          "pkexec",
          "git",
          "libayatana-appindicator3-1"
        ],
        "files": {
          "/usr/lib/freeyourdisk/freeyourdisk-helper": "../target/release/freeyourdisk-helper",
          "/usr/share/polkit-1/actions/io.freeyourdisk.policy": "../packaging/io.freeyourdisk.policy"
        }
      },
      "rpm": {
        "depends": [
          "pkexec",
          "git",
          "libayatana-appindicator3"
        ],
        "files": {
          "/usr/lib/freeyourdisk/freeyourdisk-helper": "../target/release/freeyourdisk-helper",
          "/usr/share/polkit-1/actions/io.freeyourdisk.policy": "../packaging/io.freeyourdisk.policy"
        }
      }
    }
  }
}